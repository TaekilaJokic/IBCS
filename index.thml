<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>니콜라 요키치 | THE JOKER #15</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+KR:wght@300;400;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root{--navy:#08152B;--blue:#1D428A;--gold:#FDB927;--white:#F0EDE8;--gray:#7A90B8;--border:rgba(253,185,39,0.15);}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Noto Sans KR',sans-serif;background:var(--navy);color:var(--white);overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;width:100%;z-index:200;display:flex;justify-content:space-between;align-items:center;padding:0 60px;height:64px;background:rgba(8,21,43,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);}
.logo{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:4px;color:var(--gold);}
.logo span{color:var(--white);font-size:14px;letter-spacing:2px;margin-left:10px;}
.nav-links a{color:var(--gray);text-decoration:none;margin-left:26px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;transition:color .2s;}
.nav-links a:hover{color:var(--gold);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 60px 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 100% 50%,rgba(29,66,138,0.35) 0%,transparent 70%),radial-gradient(ellipse 50% 40% at 0% 80%,rgba(253,185,39,0.05) 0%,transparent 60%);}
.hero-wm{position:absolute;right:-40px;bottom:-60px;font-family:'Bebas Neue',sans-serif;font-size:520px;line-height:1;color:rgba(29,66,138,0.06);pointer-events:none;user-select:none;}
.hero-inner{position:relative;z-index:2;max-width:900px;}
.hero-tag{display:inline-flex;align-items:center;gap:10px;background:rgba(253,185,39,0.1);border:1px solid rgba(253,185,39,0.3);padding:7px 18px;border-radius:3px;margin-bottom:28px;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);}
.hero-name{font-family:'Bebas Neue',sans-serif;font-size:110px;line-height:.88;letter-spacing:3px;margin-bottom:6px;}
.hero-name .gold{color:var(--gold);}
.hero-en{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:10px;color:var(--gray);margin-bottom:40px;}
.hero-strip{display:flex;gap:0;margin-bottom:48px;}
.hs{border-right:1px solid rgba(255,255,255,0.1);padding:0 40px 0 0;margin-right:40px;}
.hs:last-child{border:none;margin:0;padding:0;}
.hs-val{font-family:'Bebas Neue',sans-serif;font-size:58px;color:var(--gold);line-height:1;}
.hs-lbl{font-size:11px;color:var(--gray);letter-spacing:2px;text-transform:uppercase;margin-top:2px;}
.hero-desc{max-width:620px;font-size:15px;line-height:1.9;color:rgba(240,237,232,0.7);}

/* LAYOUT */
.section{padding:96px 60px;max-width:1280px;margin:0 auto;}
.sec-lbl{font-size:11px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:10px;}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:60px;letter-spacing:3px;line-height:1;margin-bottom:52px;}
.divider{max-width:1280px;margin:0 auto;height:1px;background:linear-gradient(to right,transparent,rgba(253,185,39,0.2),transparent);}

/* BIO */
.bio-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;}
.bio-text p{font-size:15px;line-height:1.9;color:rgba(240,237,232,0.75);margin-bottom:20px;}
.info-table{width:100%;border-collapse:collapse;margin-top:32px;}
.info-table tr{border-bottom:1px solid rgba(255,255,255,0.06);}
.info-table tr:hover td{background:rgba(29,66,138,0.2);}
.info-table td{padding:12px 16px;font-size:14px;}
.info-table td:first-child{color:var(--gray);font-size:11px;letter-spacing:2px;text-transform:uppercase;width:130px;}
.info-table td:last-child{font-weight:700;}
.awards-list{display:flex;flex-direction:column;gap:14px;}
.aw{display:flex;align-items:flex-start;gap:18px;background:linear-gradient(135deg,rgba(29,66,138,0.3),rgba(8,21,43,0.8));border:1px solid var(--border);border-left:4px solid var(--gold);padding:18px 22px;border-radius:8px;transition:transform .2s,border-color .2s;}
.aw:hover{transform:translateX(6px);border-color:rgba(253,185,39,0.45);}
.aw-icon{font-size:28px;flex-shrink:0;margin-top:2px;}
.aw-title{font-size:14px;font-weight:700;margin-bottom:4px;}
.aw-desc{font-size:12px;color:var(--gray);line-height:1.5;}

/* TABS */
.tabs{display:flex;gap:8px;margin-bottom:36px;}
.tab{background:transparent;border:1px solid rgba(253,185,39,0.3);color:var(--gray);padding:10px 24px;border-radius:4px;font-family:'Noto Sans KR',sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all .2s;}
.tab.active,.tab:hover{background:var(--gold);color:var(--navy);border-color:var(--gold);}
.tab-panel{display:none;}.tab-panel.active{display:block;}
.stat-row{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-bottom:36px;}
.sc{background:linear-gradient(160deg,rgba(29,66,138,0.5),rgba(8,21,43,0.9));border:1px solid var(--border);border-radius:10px;padding:26px 16px;text-align:center;transition:transform .2s,border-color .2s;}
.sc:hover{transform:translateY(-4px);border-color:rgba(253,185,39,0.35);}
.sc-val{font-family:'Bebas Neue',sans-serif;font-size:52px;color:var(--gold);line-height:1;}
.sc-lbl{font-size:10px;color:var(--gray);letter-spacing:2px;text-transform:uppercase;margin-top:5px;}
.chart-box{background:linear-gradient(135deg,rgba(29,66,138,0.3),rgba(8,21,43,0.8));border:1px solid var(--border);border-radius:14px;padding:36px;}
.chart-box h3{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin-bottom:24px;}

/* TABLE */
.tbl-wrap{overflow-x:auto;margin-top:56px;}
table{width:100%;border-collapse:collapse;}
thead th{background:rgba(253,185,39,0.1);color:var(--gold);padding:13px 14px;text-align:center;font-size:10px;letter-spacing:2px;text-transform:uppercase;border-bottom:2px solid rgba(253,185,39,0.25);font-weight:700;}
tbody td{padding:13px 14px;text-align:center;border-bottom:1px solid rgba(255,255,255,0.04);font-size:13px;color:rgba(240,237,232,0.8);transition:background .15s;}
tbody tr:hover td{background:rgba(29,66,138,0.25);}
td.hl{color:var(--gold);font-weight:900;}td.note{font-size:11px;color:var(--gray);}

/* RECORDS */
.records-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.rec{background:linear-gradient(160deg,rgba(29,66,138,0.4),rgba(8,21,43,0.85));border:1px solid var(--border);border-radius:12px;padding:28px 24px;transition:transform .2s,border-color .2s;}
.rec:hover{transform:translateY(-4px);border-color:rgba(253,185,39,0.35);}
.rec-icon{font-size:32px;margin-bottom:14px;}
.rec-title{font-size:13px;font-weight:900;color:var(--gold);letter-spacing:1px;margin-bottom:8px;}
.rec-desc{font-size:13px;color:rgba(240,237,232,0.75);line-height:1.7;}

/* PLAYSTYLE */
.play-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;}
.play-text p{font-size:15px;line-height:1.9;color:rgba(240,237,232,0.75);margin-bottom:20px;}
.traits{display:flex;flex-direction:column;gap:16px;}
.trait{background:rgba(29,66,138,0.2);border:1px solid var(--border);border-radius:8px;padding:20px 22px;}
.trait-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.trait-name{font-size:13px;font-weight:700;}
.trait-score{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gold);}
.bar-bg{height:6px;background:rgba(255,255,255,0.08);border-radius:3px;}
.bar-fill{height:6px;border-radius:3px;background:linear-gradient(to right,var(--blue),var(--gold));transition:width 1.2s ease;}

/* PERSONAL */
.personal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.pc{background:linear-gradient(160deg,rgba(29,66,138,0.35),rgba(8,21,43,0.85));border:1px solid var(--border);border-radius:12px;padding:28px 24px;transition:transform .2s;}
.pc:hover{transform:translateY(-4px);}
.pc-icon{font-size:36px;margin-bottom:14px;}
.pc-title{font-size:13px;font-weight:900;color:var(--gold);letter-spacing:1px;margin-bottom:8px;}
.pc-desc{font-size:13px;color:rgba(240,237,232,0.7);line-height:1.7;}

/* NAT */
.nat-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;}
.nat-text p{font-size:15px;line-height:1.9;color:rgba(240,237,232,0.75);margin-bottom:20px;}
.nat-cards{display:flex;flex-direction:column;gap:14px;}
.nc{display:flex;align-items:center;gap:20px;background:rgba(29,66,138,0.2);border:1px solid var(--border);border-radius:8px;padding:16px 20px;}
.nc-flag{font-size:32px;}
.nc-title{font-size:14px;font-weight:700;}
.nc-sub{font-size:12px;color:var(--gray);margin-top:3px;}

/* TIMELINE */
.timeline{position:relative;padding-left:0;}
.timeline::before{content:'';position:absolute;left:86px;top:10px;bottom:10px;width:2px;background:linear-gradient(to bottom,var(--gold),rgba(253,185,39,0.05));}
.tl{display:flex;gap:0;margin-bottom:32px;align-items:flex-start;}
.tl-yr{font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--gold);width:86px;flex-shrink:0;line-height:1;padding-top:4px;}
.tl-dot{width:12px;height:12px;border-radius:50%;background:var(--gold);border:3px solid var(--navy);flex-shrink:0;margin-top:8px;z-index:1;}
.tl-body{margin-left:26px;flex:1;background:linear-gradient(135deg,rgba(29,66,138,0.35),rgba(8,21,43,0.75));border:1px solid var(--border);border-radius:10px;padding:18px 22px;transition:border-color .2s;}
.tl:hover .tl-body{border-color:rgba(253,185,39,0.3);}
.tl-body h3{font-size:15px;font-weight:700;margin-bottom:6px;}
.tl-body p{font-size:13px;color:var(--gray);line-height:1.7;}

footer{border-top:1px solid var(--border);text-align:center;padding:40px 60px;color:var(--gray);font-size:12px;letter-spacing:1px;}
footer b{color:var(--gold);}

.rv{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease;}
.rv.on{opacity:1;transform:none;}
</style>
</head>
<body>

<nav>
  <div class="logo">JOKIĆ <span>#15 · DENVER NUGGETS</span></div>
  <div class="nav-links">
    <a href="#bio">선수 소개</a>
    <a href="#stats">스탯</a>
    <a href="#records">기록</a>
    <a href="#play">플레이스타일</a>
    <a href="#nat">국가대표</a>
    <a href="#timeline">커리어</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-wm">15</div>
  <div class="hero-inner">
    <div class="hero-tag">🏀 Denver Nuggets · Center · #15 · Serbia</div>
    <h1 class="hero-name">니콜라<br><span class="gold">요키치</span></h1>
    <p class="hero-en">NIKOLA JOKIĆ · THE JOKER</p>
    <div class="hero-strip">
      <div class="hs"><div class="hs-val">29.6</div><div class="hs-lbl">24-25 득점</div></div>
      <div class="hs"><div class="hs-val">12.7</div><div class="hs-lbl">24-25 리바운드</div></div>
      <div class="hs"><div class="hs-val">10.2</div><div class="hs-lbl">24-25 어시스트</div></div>
      <div class="hs"><div class="hs-val">3×</div><div class="hs-lbl">NBA MVP</div></div>
    </div>
    <p class="hero-desc">NBA 역사상 가장 위대한 패싱 센터. 드래프트 41순위 지명에서 시작해 3회 MVP, NBA 우승, 커리어 최초 평균 트리플더블까지—요키치의 이야기는 아직 끝나지 않았다.</p>
  </div>
</section>

<div class="divider"></div>

<!-- BIO -->
<div class="section rv" id="bio">
  <div class="sec-lbl">선수 소개</div>
  <div class="sec-title">WHO IS THE JOKER?</div>
  <div class="bio-grid">
    <div>
      <div class="bio-text">
        <p>니콜라 요키치는 1995년 세르비아 북부 소도시 솜보르(Sombor)에서 태어났다. 두 형 스트라힌야와 네마냐의 영향으로 농구를 시작했으며, 세르비아의 포지션리스(positionless) 농구 교육 시스템 속에서 키가 큰 선수도 드리블·패스·슛을 고루 익히는 훈련을 받았다.</p>
        <p>세르비아 클럽 메가 바스켓(Mega Basket)에서 성장한 그는 2014년 NBA 드래프트 2라운드 41번으로 덴버 너기츠에 지명됐다. 당시 중계 화면에는 피자를 먹고 있는 모습이 포착돼 화제가 됐지만, 그로부터 10년 뒤 그는 NBA 역사상 가장 위대한 선수 반열에 오른다.</p>
        <p>2021·2022·2024년 3회 MVP를 수상하며 래리 버드, 매직 존슨, 모세스 말론과 어깨를 나란히 했다. 2023년 파이널 MVP를 겸하며 덴버의 창단 첫 우승을 이끌었고, 2024-25 시즌에는 오스카 로버트슨, 러셀 웨스트브룩에 이어 역사상 세 번째로 시즌 평균 트리플더블을 달성했다.</p>
      </div>
      <table class="info-table">
        <tr><td>생년월일</td><td>1995년 2월 19일 (만 31세)</td></tr>
        <tr><td>출생지</td><td>세르비아 솜보르 (Sombor)</td></tr>
        <tr><td>신장</td><td>211cm (6′11″)</td></tr>
        <tr><td>체중</td><td>129kg (284 lbs)</td></tr>
        <tr><td>포지션</td><td>센터 (Center)</td></tr>
        <tr><td>등번호</td><td>#15</td></tr>
        <tr><td>소속팀</td><td>덴버 너기츠 (Denver Nuggets)</td></tr>
        <tr><td>드래프트</td><td>2014년 2라운드 41번 (전체 41순위)</td></tr>
        <tr><td>NBA 경력</td><td>10시즌 (2015-현재)</td></tr>
        <tr><td>별명</td><td>The Joker · Big Honey · Cookie Monster</td></tr>
        <tr><td>커리어 연봉</td><td>$247,432,182 이상</td></tr>
        <tr><td>2024-25 연봉</td><td>$51,415,938</td></tr>
      </table>
    </div>
    <div class="awards-list">
      <div class="aw"><div class="aw-icon">🏆</div><div><div class="aw-title">NBA 챔피언십 · 파이널 MVP (2023)</div><div class="aw-desc">덴버 창단 첫 우승 주역. 파이널 5경기 평균 30.2점·14.0리바·7.2어시스트. 플레이오프 역대 최다 트리플더블(10개) 기록.</div></div></div>
      <div class="aw"><div class="aw-icon">⭐</div><div><div class="aw-title">NBA MVP 3회 (2021·2022·2024)</div><div class="aw-desc">래리 버드·매직 존슨·모세스 말론과 함께 3회 MVP 달성. 드래프트 2라운드 출신 최초, 역대 9번째 3회 이상 수상자.</div></div></div>
      <div class="aw"><div class="aw-icon">🌟</div><div><div class="aw-title">NBA 올스타 7회 선정 (2019~2025)</div><div class="aw-desc">2019년 첫 선정 이후 7년 연속 올스타. 2024년까지 4회 연속 선발(스타터)로 출전.</div></div></div>
      <div class="aw"><div class="aw-icon">📊</div><div><div class="aw-title">All-NBA 1st Team 4회 선정</div><div class="aw-desc">2019·2021·2022·2024 시즌 All-NBA 1st Team. 세르비아 선수 역대 최초 선정.</div></div></div>
      <div class="aw"><div class="aw-icon">🥈</div><div><div class="aw-title">올림픽 은메달 (2016) · 동메달 (2024)</div><div class="aw-desc">세르비아 국가대표로 리우 올림픽 은메달, 파리 올림픽 동메달 획득.</div></div></div>
      <div class="aw"><div class="aw-icon">🔰</div><div><div class="aw-title">NBA All-Rookie 1st Team (2016)</div><div class="aw-desc">루키 시즌 평균 10.0점·7.0리바·2.4어시스트로 올 루키 1팀 선정.</div></div></div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- STATS -->
<div class="section rv" id="stats">
  <div class="sec-lbl">스탯 & 기록</div>
  <div class="sec-title">BY THE NUMBERS</div>
  <div class="tabs">
    <button class="tab active" onclick="switchTab('t2425',this)">2024-25 시즌</button>
    <button class="tab" onclick="switchTab('t2324',this)">2023-24 시즌</button>
    <button class="tab" onclick="switchTab('t2223',this)">2022-23 시즌</button>
    <button class="tab" onclick="switchTab('tcar',this)">커리어 통산</button>
  </div>
  <div id="t2425" class="tab-panel active">
    <div class="stat-row">
      <div class="sc"><div class="sc-val">29.6</div><div class="sc-lbl">평균 득점</div></div>
      <div class="sc"><div class="sc-val">12.7</div><div class="sc-lbl">평균 리바운드</div></div>
      <div class="sc"><div class="sc-val">10.2</div><div class="sc-lbl">평균 어시스트</div></div>
      <div class="sc"><div class="sc-val">57.7</div><div class="sc-lbl">야투율 (%)</div></div>
      <div class="sc"><div class="sc-val">41.7</div><div class="sc-lbl">3점 성공률 (%)</div></div>
      <div class="sc"><div class="sc-val">1.8</div><div class="sc-lbl">평균 스틸</div></div>
    </div>
    <div class="chart-box"><h3>2024-25 시즌 주요 스탯</h3><canvas id="c2425" height="75"></canvas></div>
  </div>
  <div id="t2324" class="tab-panel">
    <div class="stat-row">
      <div class="sc"><div class="sc-val">26.4</div><div class="sc-lbl">평균 득점</div></div>
      <div class="sc"><div class="sc-val">12.4</div><div class="sc-lbl">평균 리바운드</div></div>
      <div class="sc"><div class="sc-val">9.0</div><div class="sc-lbl">평균 어시스트</div></div>
      <div class="sc"><div class="sc-val">58.3</div><div class="sc-lbl">야투율 (%)</div></div>
      <div class="sc"><div class="sc-val">35.9</div><div class="sc-lbl">3점 성공률 (%)</div></div>
      <div class="sc"><div class="sc-val">1.4</div><div class="sc-lbl">평균 스틸</div></div>
    </div>
    <div class="chart-box"><h3>2023-24 시즌 주요 스탯 (3회 MVP)</h3><canvas id="c2324" height="75"></canvas></div>
  </div>
  <div id="t2223" class="tab-panel">
    <div class="stat-row">
      <div class="sc"><div class="sc-val">24.5</div><div class="sc-lbl">평균 득점</div></div>
